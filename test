<HTML>
<HEAD>
<TITLE>我的夢幻萌寵</TITLE>
<META HTTP-EQUIV="X-UA-Compatible" CONTENT="IE=edge">
<META CHARSET="utf-8">
<HTA:APPLICATION 
    ID="oPetGame"
    APPLICATIONNAME="CutePetDesktop"
    BORDER="none"
    BORDERSTYLE="normal"
    CAPTION="no"
    ICON=""
    MAXIMIZEBUTTON="no"
    MINIMIZEBUTTON="no"
    SHOWINTASKBAR="yes"
    SINGLEINSTANCE="yes"
    SYSMENU="no"
    WINDOWSTATE="normal"
/>
<STYLE>
    * { box-sizing: border-box; user-select: none; -webkit-user-select: none; font-family: "Microsoft JhengHei", sans-serif; }
    body { margin: 0; padding: 0; background: #232125; color: #e3dec3; overflow: hidden; font-size: 12px; }
    #win-chrome { width: 400px; height: 520px; background: #2d2a2e; border: 2px solid #443f43; display: flex; flex-direction: column; position: relative; box-shadow: 0 8px 25px rgba(0,0,0,0.5); border-radius: 8px; }
    #title-bar { height: 32px; background: #222022; display: flex; justify-content: space-between; align-items: center; padding: 0 10px; border-bottom: 1px solid #3a363a; }
    .title-text { font-size: 11px; font-weight: bold; color: #ab9df2; letter-spacing: 1px; }
    .win-btn { width: 20px; height: 20px; background: #3a363a; border: none; color: #ff6188; cursor: pointer; font-weight: bold; font-size: 11px; display: flex; align-items: center; justify-content: center; transition: all 0.2s; border-radius: 4px; }
    .win-btn:hover { background: #ff6188; color: #2d2a2e; }
    
    #tabs-header { display: flex; background: #222022; border-bottom: 1px solid #3a363a; padding: 0 4px; }
    .tab-link { padding: 8px 16px; background: transparent; border: none; color: #787176; cursor: pointer; font-size: 12px; font-weight: bold; border-bottom: 2px solid transparent; transition: all 0.2s; }
    .tab-link:hover { color: #e3dec3; }
    .tab-link.active { color: #a9dc76; border-bottom-color: #a9dc76; background: rgba(169,220,118,0.05); }
    
    .tab-content { display: none; flex: 1; flex-direction: column; padding: 12px; height: 418px; overflow: hidden; }
    .tab-content.active { display: flex; }
    
    .panel { background: #222022; border: 1px solid #3a363a; border-radius: 6px; display: flex; flex-direction: column; margin-bottom: 10px; }
    .panel-header { background: #2d2a2e; padding: 6px 10px; border-bottom: 1px solid #3a363a; font-size: 11px; font-weight: bold; color: #787176; display: flex; justify-content: space-between; border-radius: 5px 5px 0 0; }
    
    #canvas-container { height: 180px; position: relative; display: flex; justify-content: center; align-items: center; background: #1e1c1e; cursor: pointer; border-radius: 6px; overflow: hidden; border: 1px solid #3a363a; margin-bottom: 10px; }
    #dmg-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; }
    .pop-text { position: absolute; font-weight: bold; pointer-events: none; font-size: 13px; animation: pMove 0.6s ease-out forwards; }
    @keyframes pMove { 0% { transform: translateY(0); opacity: 0; } 10% { opacity: 1; } 100% { transform: translateY(-40px); opacity: 0; } }
    
    .curr-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 4px; }
    .curr-box { background: #222022; border: 1px solid #3a363a; padding: 8px; border-radius: 6px; text-align: center; }
    .curr-lbl { font-size: 11px; color: #787176; margin-bottom: 2px; }
    .curr-val { font-size: 14px; font-weight: bold; color: #ffd866; font-family: Arial; }
    
    .hud-box { padding: 8px; border-top: 1px solid #3a363a; background: #222022; border-radius: 0 0 5px 5px; }
    .hud-row { display: flex; justify-content: space-between; font-size: 11px; color: #787176; margin-bottom: 4px; }
    .bar-container { height: 5px; background: #1e1c1e; border-radius: 3px; overflow: hidden; }
    .bar-fill { height: 100%; width: 0%; transition: width 0.1s linear; }
    
    .scroller { flex: 1; overflow-y: scroll; display: flex; flex-direction: column; gap: 6px; pr: 2px; }
    .scroller::-webkit-scrollbar { width: 4px; }
    .scroller::-webkit-scrollbar-track { background: transparent; }
    .scroller::-webkit-scrollbar-thumb { background: #3a363a; border-radius: 2px; }
    
    .card { background: #222022; border: 1px solid #3a363a; border-radius: 6px; padding: 8px; display: flex; justify-content: space-between; align-items: center; }
    .card-meta { display: flex; flex-direction: column; gap: 2px; width: 240px; }
    .card-title { font-size: 12px; font-weight: bold; color: #e3dec3; }
    .card-desc { font-size: 11px; color: #787176; }
    .card-cost { font-size: 11px; font-weight: bold; color: #ff6188; margin-top: 1px; }
    
    .btn-action { background: #3a363a; border: 1px solid #4d464b; border-radius: 4px; color: #e3dec3; padding: 5px 10px; min-width: 65px; text-align: center; cursor: pointer; font-size: 11px; font-weight: bold; }
    .btn-action:hover:not(:disabled) { background: #4d464b; border-color: #787176; color: #fff; }
    .btn-action:active:not(:disabled) { transform: scale(0.96); }
    .btn-action:disabled { background: #1e1c1e; border-color: #222022; color: #443f43; cursor: not-allowed; }
    
    #log-stream { flex: 1; padding: 6px; font-size: 11px; color: #787176; display: flex; flex-direction: column; justify-content: flex-end; line-height: 1.5; }
</STYLE>
</HEAD>
<BODY>

<DIV ID="win-chrome">
    <DIV ID="title-bar">
        <DIV CLASS="title-text">🪐 萌寵觀測箱</DIV>
        <BUTTON CLASS="win-btn" ONCLICK="window.close()">✕</BUTTON>
    </DIV>

    <DIV ID="tabs-header">
        <BUTTON CLASS="tab-link active" ONCLICK="switchTab('tab-main', this)">狀態</BUTTON>
        <BUTTON CLASS="tab-link" ONCLICK="switchTab('tab-shop', this)">商店</BUTTON>
        <BUTTON CLASS="tab-link" ONCLICK="switchTab('tab-log', this)">日誌</BUTTON>
    </DIV>

    <DIV ID="tab-main" CLASS="tab-content active">
        <DIV ID="canvas-container" ONCLICK="execManualClick(event)">
            <CANVAS ID="viewCanvas" WIDTH="374" HEIGHT="180"></CANVAS>
            <DIV ID="dmg-layer"></DIV>
        </DIV>
        
        <DIV CLASS="curr-grid">
            <DIV CLASS="curr-box">
                <DIV CLASS="curr-lbl">金幣</DIV>
                <DIV CLASS="curr-val" ID="v-gold">0</DIV>
            </DIV>
            <DIV CLASS="curr-box">
                <DIV CLASS="curr-lbl">幻星</DIV>
                <DIV CLASS="curr-val" ID="v-shards" STYLE="color:#78dce8;">0</DIV>
            </DIV>
        </DIV>

        <DIV CLASS="panel" STYLE="margin-top:2px;">
            <DIV CLASS="panel-header"><SPAN ID="pet-state-lbl">運作中</SPAN><SPAN ID="stage-board">--</SPAN></DIV>
            <DIV CLASS="hud-box">
                <DIV CLASS="hud-row"><SPAN>飽食度</SPAN><SPAN ID="lbl-satiety">100%</SPAN></DIV>
                <DIV CLASS="bar-container"><DIV ID="bar-satiety" CLASS="bar-fill" STYLE="background:#ff6188;"></DIV></DIV>
                <DIV CLASS="hud-row" STYLE="margin-top:8px;"><SPAN>心情凝聚度</SPAN><SPAN ID="lbl-mood">0.0s</SPAN></DIV>
                <DIV CLASS="bar-container"><DIV ID="bar-mood" CLASS="bar-fill" STYLE="background:#78dce8;"></DIV></DIV>
            </DIV>
        </DIV>
    </DIV>

    <DIV ID="tab-shop" CLASS="tab-content">
        <DIV CLASS="scroller" ID="scroller-gear"></DIV>
    </DIV>

    <DIV ID="tab-log" CLASS="tab-content">
        <DIV CLASS="panel" STYLE="flex:1; margin:0;">
            <DIV ID="log-stream"></DIV>
        </DIV>
    </DIV>
</DIV>

<SCRIPT>
    window.resizeTo(400, 520);
    window.moveTo((window.screen.availWidth - 400) / 2, (window.screen.availHeight - 520) / 2);

    var db = {
        gold: 0,
        shards: 0,
        totalGears: 0,
        satiety: 100,
        moodProgress: 0,
        lastTick: new Date().getTime(),
        gear: {
            g1: { id: "g1", name: "🍼 營養補給物資", lvl: 0, baseCost: 10, costMult: 1.4, val: 2, desc: "+2 金幣/週期，補給 20% 飽食度", costType: "gold" },
            g2: { id: "g2", name: "🐱 裝飾性特製貓耳", lvl: 0, baseCost: 50, costMult: 1.5, val: 120, desc: "縮短 120毫秒 產金時間間隔", costType: "gold" },
            g3: { id: "g3", name: "🕊️ 輕質微型不對稱雙翼", lvl: 0, baseCost: 250, costMult: 1.6, val: 1, desc: "每週期有機率額外獲得 1 幻星", costType: "gold" },
            g4: { id: "g4", name: "👑 小型精製金屬冕", lvl: 0, baseCost: 1000, costMult: 1.8, val: 0.4, desc: "全圖生產收益永久提升 40%", costType: "gold" },
            g5: { id: "g5", name: "🔮 軌道控制干涉制導球", lvl: 0, baseCost: 5, costMult: 2.0, val: 3, desc: "手動點擊交互收益提升 300%", costType: "shards" }
        }
    };

    var cfg = {
        baseAutoInt: 2500,
        baseMoodInt: 5000,
        canvasW: 374,
        canvasH: 180
    };

    var cvs, ctx, animFrame = 0, petAction = "idle", actionTimer = 0;

    function boot() {
        cvs = document.getElementById("viewCanvas");
        ctx = cvs.getContext("2d");
        buildUI();
        tick();
        setInterval(tick, 40);
        pushLog("環境觀測連線成功。");
    }

    function switchTab(tabId, btn) {
        var contents = document.getElementsByClassName("tab-content");
        for (var i = 0; i < contents.length; i++) contents[i].className = "tab-content";
        var links = document.getElementsByClassName("tab-link");
        for (var i = 0; i < links.length; i++) links[i].className = "tab-link";
        document.getElementById(tabId).className = "tab-content active";
        btn.className = "tab-link active";
    }

    function buildUI() {
        var html = "";
        for (var k in db.gear) {
            var item = db.gear[k];
            html += '<DIV CLASS="card" ID="c-gear-' + item.id + '">' +
                    '<DIV CLASS="card-meta">' +
                    '<SPAN CLASS="card-title" ID="lbl-name-' + item.id + '">' + item.name + '</SPAN>' +
                    '<SPAN CLASS="card-desc">' + item.desc + '</SPAN>' +
                    '<SPAN CLASS="card-cost" ID="lbl-cost-' + item.id + '">--</SPAN>' +
                    '</DIV>' +
                    '<BUTTON CLASS="btn-action" ID="btn-gear-' + item.id + '" ONCLICK="buyGear(\'' + item.id + '\')">升級</BUTTON>' +
                    '</DIV>';
        }
        document.getElementById("scroller-gear").innerHTML = html;
        syncData();
    }

    function getCost(item) {
        return Math.floor(item.baseCost * Math.pow(item.costMult, item.lvl));
    }

    function syncData() {
        document.getElementById("v-gold").innerText = db.gold;
        document.getElementById("v-shards").innerText = db.shards;

        db.totalGears = 0;
        for (var k in db.gear) {
            var item = db.gear[k];
            var cost = getCost(item);
            db.totalGears += item.lvl;
            document.getElementById("lbl-name-" + item.id).innerText = item.name + " [Lv." + item.lvl + "]";
            
            var cSign = item.costType == "gold" ? " 金幣" : " 幻星";
            document.getElementById("lbl-cost-" + item.id).innerText = "需求: " + cost + cSign;
            
            if (item.costType == "gold") {
                document.getElementById("btn-gear-" + item.id).disabled = (db.gold < cost);
            } else {
                document.getElementById("btn-gear-" + item.id).disabled = (db.shards < cost);
            }
        }

        var stageStr = "原型體";
        if (db.totalGears >= 4) stageStr = "變異株";
        if (db.totalGears >= 10) stageStr = "進化型";
        if (db.totalGears >= 18) stageStr = "完全體";
        document.getElementById("stage-board").innerText = "型態: " + stageStr;

        document.getElementById("lbl-satiety").innerText = db.satiety + "%";
        document.getElementById("lbl-mood").innerText = (getMoodInterval() / 1000).toFixed(1) + "s";
    }

    function getAutoInterval() {
        return Math.max(600, cfg.baseAutoInt - (db.gear.g2.lvl * db.gear.g2.val));
    }

    function getMoodInterval() {
        return cfg.baseMoodInt;
    }

    function buyGear(id) {
        var item = db.gear[id];
        var cost = getCost(item);
        if (item.costType == "gold" && db.gold >= cost) {
            db.gold -= cost;
            item.lvl++;
            petAction = "happy"; actionTimer = 20;
            pushLog("已加載補強單元: " + item.name);
            if(id == "g1") db.satiety = Math.min(100, db.satiety + 20);
            syncData();
        } else if (item.costType == "shards" && db.shards >= cost) {
            db.shards -= cost;
            item.lvl++;
            petAction = "happy"; actionTimer = 20;
            pushLog("已部署模組組件: " + item.name);
            syncData();
        }
    }

    function getOutputValues() {
        var gAdd = 1 + (db.gear.g1.lvl * db.gear.g1.val);
        var sAdd = 0 + (db.gear.g3.lvl * db.gear.g3.val);
        var mult = 1 + (db.gear.g4.lvl * db.gear.g4.val);
        return {
            gold: Math.floor(gAdd * mult),
            shards: Math.floor(sAdd * mult)
        };
    }

    function tick() {
        var now = new Date().getTime();
        var delta = now - db.lastTick;
        db.lastTick = now;

        animFrame++;
        if (actionTimer > 0) {
            actionTimer--;
            if (actionTimer <= 0) petAction = "idle";
        }

        var autoInt = getAutoInterval();
        if (db.satiety > 0) {
            var out = getOutputValues();
            db.gold += out.gold;
            db.shards += out.shards;
            if (out.gold > 0 && animFrame % Math.floor(autoInt/40) === 0) {
                popText(cfg.canvasW / 2, 50, "+" + out.gold, "#ffd866");
                if (Math.random() < 0.08) db.satiety = Math.max(0, db.satiety - 1);
            }
            if (out.shards > 0 && animFrame % Math.floor(autoInt/40) === 0) {
                popText(cfg.canvasW / 2 + 25, 65, "+" + out.shards + "⭐", "#78dce8");
            }
        }

        var moodInt = getMoodInterval();
        db.moodProgress += delta;
        if (db.moodProgress >= moodInt) {
            db.moodProgress = 0;
            if(db.satiety > 20) {
                db.shards += 1;
                popText(cfg.canvasW / 2 - 30, 75, "+1⭐", "#78dce8");
                pushLog("生物特徵穩定，聚合產出微量幻星");
            }
        }
        document.getElementById("bar-mood").style.width = Math.min(100, (db.moodProgress / moodInt) * 100) + "%";
        document.getElementById("bar-satiety").style.width = db.satiety + "%";

        if (db.satiety <= 0) {
            document.getElementById("pet-state-lbl").innerText = "極度飢餓";
            document.getElementById("pet-state-lbl").style.color = "#ff6188";
        } else {
            document.getElementById("pet-state-lbl").innerText = "生命特徵運作中";
            document.getElementById("pet-state-lbl").style.color = "#a9dc76";
        }

        syncData();
        render();
    }

    function execManualClick(e) {
        var rect = cvs.getBoundingClientRect();
        var x = e.clientX - rect.left;
        var y = e.clientY - rect.top;

        var out = getOutputValues();
        var clickAmp = 1 + (db.gear.g5.lvl * db.gear.g5.val);
        var clickGold = Math.floor(out.gold * clickAmp);
        
        db.gold += clickGold;
        popText(x, y, "撫摸 +" + clickGold, "#ff6188");
        
        petAction = "happy";
        actionTimer = 25;

        db.moodProgress += Math.floor(getMoodInterval() * 0.08);
        syncData();
    }

    function popText(x, y, txt, color) {
        var container = document.getElementById("dmg-layer");
        var el = document.createElement("div");
        el.className = "pop-text";
        el.style.left = (x - 40) + "px";
        el.style.top = (y - 15) + "px";
        el.style.color = color;
        el.innerText = txt;
        container.appendChild(el);
        setTimeout(function() { if(el && el.parentNode) container.removeChild(el); }, 600);
    }

    function pushLog(txt) {
        var s = document.getElementById("log-stream");
        var line = document.createElement("div");
        line.innerText = "> " + txt;
        s.appendChild(line);
        if (s.childNodes.length > 15) s.removeChild(s.firstChild);
    }

    function drawEllipse(ctx, cx, cy, rx, ry, color) {
        ctx.save();
        ctx.beginPath();
        ctx.translate(cx, cy);
        ctx.scale(rx, ry);
        ctx.arc(0, 0, 1, 0, Math.PI * 2);
        ctx.fillStyle = color;
        ctx.fill();
        ctx.restore();
    }

    function render() {
        ctx.clearRect(0, 0, cfg.canvasW, cfg.canvasH);

        var cx = cfg.canvasW / 2;
        var cy = cfg.canvasH / 2 + 10;
        
        var breathe = Math.sin(animFrame * 0.08) * 1.5;
        var floatY = Math.sin(animFrame * 0.04) * 3;
        
        var py = cy + floatY;

        var g2Lvl = db.gear.g2.lvl;
        var g3Lvl = db.gear.g3.lvl;
        var g4Lvl = db.gear.g4.lvl;
        var g5Lvl = db.gear.g5.lvl;

        drawEllipse(ctx, cx, cy + 28, 35 + breathe, 7, "rgba(0, 0, 0, 0.3)");

        if (g3Lvl > 0) {
            ctx.save();
            var wingFlap = Math.sin(animFrame * 0.15) * 4;
            ctx.fillStyle = "#494447";
            ctx.strokeStyle = "#5b5459";
            ctx.lineWidth = 1.5;
            
            ctx.beginPath();
            ctx.moveTo(cx - 24, py);
            ctx.bezierCurveTo(cx - 55, py - 22 + wingFlap, cx - 45, py + 8 + wingFlap, cx - 24, py + 12);
            ctx.fill(); ctx.stroke();
            
            ctx.beginPath();
            ctx.moveTo(cx + 24, py);
            ctx.bezierCurveTo(cx + 55, py - 22 + wingFlap, cx + 45, py + 8 + wingFlap, cx + 24, py + 12);
            ctx.fill(); ctx.stroke();
            ctx.restore();
        }

        if (g2Lvl > 0) {
            ctx.fillStyle = "#ff6188";
            ctx.beginPath();
            ctx.moveTo(cx - 26, py - 12);
            ctx.lineTo(cx - 36, py - 32);
            ctx.lineTo(cx - 15, py - 22);
            ctx.closePath(); ctx.fill();
            ctx.beginPath();
            ctx.moveTo(cx + 26, py - 12);
            ctx.lineTo(cx + 36, py - 32);
            ctx.lineTo(cx + 15, py - 22);
            ctx.closePath(); ctx.fill();
        }

        var petColor = "#938aa9";
        if(db.satiety <= 0) petColor = "#524f54";
        else if(petAction == "happy") petColor = "#ab9df2";

        drawEllipse(ctx, cx, py + 4, 34 + breathe, 26 - breathe, petColor);
        drawEllipse(ctx, cx - 30, py + 14, 8, 8, petColor);

        var eyeW = 3;
        var eyeH = 5;
        var blink = (animFrame % 65 > 61);
        
        ctx.fillStyle = "#2d2a2e";
        
        if (db.satiety <= 0) {
            ctx.lineWidth = 2;
            ctx.strokeStyle = "#2d2a2e";
            ctx.beginPath(); ctx.moveTo(cx - 12, py - 2); ctx.lineTo(cx - 8, py + 2); ctx.stroke();
            ctx.beginPath(); ctx.moveTo(cx + 8, py + 2); ctx.lineTo(cx + 12, py - 2); ctx.stroke();
            ctx.beginPath(); ctx.arc(cx, py + 11, 4, Math.PI, 0); ctx.stroke();
        } else if (petAction == "happy") {
            ctx.lineWidth = 2;
            ctx.strokeStyle = "#2d2a2e";
            ctx.beginPath(); ctx.arc(cx - 10, py, 3, Math.PI, 0); ctx.stroke();
            ctx.beginPath(); ctx.arc(cx + 10, py, 3, Math.PI, 0); ctx.stroke();
            ctx.fillStyle = "#ff6188";
            ctx.beginPath();
            ctx.arc(cx, py + 5, 4, 0, Math.PI);
            ctx.fill();
        } else {
            if (!blink) {
                drawEllipse(ctx, cx - 10, py, eyeW, eyeH, "#2d2a2e");
                drawEllipse(ctx, cx + 10, py, eyeW, eyeH, "#2d2a2e");
                drawEllipse(ctx, cx - 10.5, py - 1.5, 1, 1.5, "#fff");
                drawEllipse(ctx, cx + 9.5, py - 1.5, 1, 1.5, "#fff");
            } else {
                ctx.lineWidth = 1.5;
                ctx.strokeStyle = "#2d2a2e";
                ctx.beginPath(); ctx.moveTo(cx - 13, py); ctx.lineTo(cx - 7, py); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(cx + 7, py); ctx.lineTo(cx + 13, py); ctx.stroke();
            }
            drawEllipse(ctx, cx - 17, py + 5, 4, 2, "rgba(255, 97, 136, 0.3)");
            drawEllipse(ctx, cx + 17, py + 5, 4, 2, "rgba(255, 97, 136, 0.3)");
            
            ctx.lineWidth = 1.2;
            ctx.strokeStyle = "#2d2a2e";
            ctx.beginPath(); ctx.arc(cx - 2, py + 5, 2, 0, Math.PI); ctx.stroke();
            ctx.beginPath(); ctx.arc(cx + 2, py + 5, 2, 0, Math.PI); ctx.stroke();
        }

        if (g4Lvl > 0) {
            ctx.save();
            ctx.translate(cx, py - 22);
            ctx.fillStyle = "#ffd866";
            ctx.beginPath();
            ctx.moveTo(-9, 0);
            ctx.lineTo(-11, -7);
            ctx.lineTo(-5, -3);
            ctx.lineTo(0, -12);
            ctx.lineTo(5, -3);
            ctx.lineTo(11, -7);
            ctx.lineTo(9, 0);
            ctx.closePath();
            ctx.fill();
            ctx.restore();
        }

        if (g5Lvl > 0) {
            var orbCount = Math.min(4, g5Lvl);
            for (var i = 0; i < orbCount; i++) {
                var angle = (animFrame * 0.05) + (i * (Math.PI * 2) / orbCount);
                var orbX = cx + Math.cos(angle) * 50;
                var orbY = py + Math.sin(angle) * 15;
                
                ctx.save();
                ctx.beginPath();
                ctx.arc(orbX, orbY, 4, 0, Math.PI * 2);
                var grad = ctx.createRadialGradient(orbX, orbY, 1, orbX, orbY, 4);
                grad.addColorStop(0, "#fff");
                grad.addColorStop(1, "#78dce8");
                ctx.fillStyle = grad;
                ctx.fill();
                ctx.restore();
            }
        }
    }

    window.onload = boot;
</SCRIPT>
</BODY>
</HTML>
