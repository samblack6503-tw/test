<script>




/* ======================
   Idle Engine
====================== */


var lastTick=Date.now();



function idleEngine(){


var now=Date.now();


var delta=
now-lastTick;


lastTick=now;



var count=
Math.floor(
delta/getCurrentInterval()
);



if(count>0){


addGold(
getIdleIncome()*count
);


updateUI();


}


}



setInterval(
idleEngine,
1000
);





/* ======================
   自動存檔
====================== */


setInterval(

function(){

saveGame();

},

10000

);






/* ======================
   商店升級
====================== */


function buyUpgrade(type){


var item=
gameState.upgrades[type];



if(

gameState.gold>=item.cost

&&

item.lvl<item.max

){


gameState.gold-=item.cost;



item.lvl++;



item.cost=

Math.floor(

item.cost*

item.mult

);



updateUI();


}


}








/* ======================
   轉職系統
====================== */


function triggerPrestige(){


if(

gameState.gold <

gameState.prestigeRequirement

)

return;



if(
gameState.jobLevel>=3
)

return;




gameState.gold-=

gameState.prestigeRequirement;



gameState.jobLevel++;



/*
永久力量
*/

gameState.rebirthPower++;





/*
保留30%裝備
*/


for(
var key in gameState.upgrades
){


var u=
gameState.upgrades[key];


u.lvl=

Math.floor(
u.lvl*0.3
);



u.cost=u.baseCost;



for(
var i=0;
i<u.lvl;
i++
){

u.cost=

Math.floor(
u.cost*u.mult
);

}


}





gameState.prestigeRequirement*=6;




alert(

"✨ 覺醒成功！\n\n"+

"晉升："+
gameState.jobNames[
gameState.jobLevel
]+

"\n\n永久力量 +1\n"+
"全部收益 +10%"

);



updateUI();


}







/* ======================
   遠征系統
====================== */


function startAdventure(){


if(
gameState.jobLevel<1
||
advState.away
)

return;




advState.away=true;


advState.time=30;




advState.timer=

setInterval(

function(){



advState.time--;





if(
advState.time<=0
){



clearInterval(
advState.timer
);



advState.away=false;




var reward=

1500+

gameState.jobLevel*
5000;



reward*=

(
1+
gameState.upgrades.crown.lvl
);



addGold(reward);





alert(

"⚔️ 遠征完成！\n\n"+
"獲得 "+
Math.floor(reward)+
" 金幣"

);





updateUI();



}

else{


updateUI();


}



},

1000

);




updateUI();


}









/* ======================
   UI更新
====================== */


function updateUI(){



if(
!document.getElementById("gold")
)

return;





document.getElementById("gold")
.innerHTML=

gameState.gold+
" 💰";





document.getElementById("job")
.innerHTML=

gameState.jobNames[
gameState.jobLevel
];





document.getElementById("gps")
.innerHTML=

(

getIdleIncome()

/

(getCurrentInterval()/1000)

)

.toFixed(1);





document.getElementById("rebirth")
.innerHTML=

gameState.rebirthPower;






for(
var k in gameState.upgrades
){


var u=
gameState.upgrades[k];



document.getElementById(
"lv-"+k
).innerHTML=

"Lv."+u.lvl;




document.getElementById(
"cost-"+k
).innerHTML=

u.lvl>=u.max?

"MAX":

u.cost+" 💰";



}





var btn=

document.getElementById(
"prestige"
);





if(
gameState.jobLevel>=3
){


btn.innerHTML=

"已達最高境界";


btn.disabled=true;


}

else{


btn.disabled=

gameState.gold <

gameState.prestigeRequirement;



btn.innerHTML=

"轉職 → "+

gameState.jobNames[
gameState.jobLevel+1
]+

"<br>需求 "+

gameState.prestigeRequirement+
" 💰";


}







if(gameState.jobLevel>=1){



document.getElementById(
"adv"
).style.display="block";



document.getElementById(
"advBtn"
).disabled=

advState.away;



document.getElementById(
"advBtn"
).innerHTML=

advState.away?

"遠征中 "+advState.time+" 秒":

"⚔️ 開始遠征";



}

else{


document.getElementById(
"adv"
).style.display="none";


}



}




</script>
<script>


/* =========================
   Canvas 初始化
========================= */


function initCanvas(){


canvas=
document.getElementById("canvas");


ctx=
canvas.getContext("2d");



for(
var i=0;i<40;i++
){

envState.drops.push({

x:Math.random()*canvas.width,

y:Math.random()*canvas.height,

speed:2+Math.random()*5

});

}




for(
var i=0;i<30;i++
){

envState.stars.push({

x:Math.random()*canvas.width,

y:Math.random()*150,

r:1+Math.random()*2

});

}





for(
var i=0;i<35;i++
){

envState.particles.push({

angle:Math.random()*6.28,

radius:30+Math.random()*50,

speed:0.01+Math.random()*0.03

});

}



}







/* =========================
   Canvas 點擊
========================= */


function canvasClick(e){


if(advState.away)
return;



var rect=
canvas.getBoundingClientRect();



var x=
e.clientX-rect.left;



var y=
e.clientY-rect.top;




var value=
getClickIncome();



addGold(value);




fxState.scale=0.8;




fxState.texts.push({

x:x,

y:y,

text:

(showCrit?"CRITICAL ":"+")+
value,

life:100,

crit:showCrit

});





fxState.waves.push({

x:x,

y:y,

r:5,

life:1

});



updateUI();



}







/* =========================
   動畫更新
========================= */


function updateAnimation(){


if(
fxState.scale<1
)

fxState.scale+=0.05;






for(
var i=fxState.texts.length-1;
i>=0;
i--
){


var t=
fxState.texts[i];


t.y-=1;


t.life-=2;



if(t.life<=0)

fxState.texts.splice(i,1);


}






for(
var i=fxState.waves.length-1;
i>=0;
i--
){


var w=
fxState.waves[i];


w.r+=4;


w.life-=0.05;



if(w.life<=0)

fxState.waves.splice(i,1);



}


}








/* =========================
   主渲染
========================= */


var angle=0;



function render(){


ctx.clearRect(

0,

0,

canvas.width,

canvas.height

);



angle+=0.04;





var bg=

ctx.createLinearGradient(

0,

0,

0,

canvas.height

);



bg.addColorStop(
0,
"#050816"
);



bg.addColorStop(
1,
"#172554"
);



ctx.fillStyle=bg;


ctx.fillRect(

0,

0,

canvas.width,

canvas.height

);








/* 星空 */


ctx.fillStyle="#ffffff";



for(
var i=0;
i<envState.stars.length;
i++
){


var s=
envState.stars[i];

ctx.beginPath();

ctx.arc(

s.x,

s.y,

s.r,

0,

Math.PI*2

);


ctx.fill();



}








var cx=
canvas.width/2;


var cy=
canvas.height/2;



var color=

gameState.jobColors[
gameState.jobLevel
];








/* 光環 */


var aura=

ctx.createRadialGradient(

cx,

cy,

5,

cx,

cy,

80

);



aura.addColorStop(
0,
"#ffffff"
);


aura.addColorStop(
0.4,
color
);


aura.addColorStop(
1,
"transparent"
);



ctx.fillStyle=aura;



ctx.beginPath();


ctx.arc(

cx,

cy,

80,

0,

Math.PI*2

);



ctx.fill();








/* 粒子 */


for(
var i=0;
i<envState.particles.length;
i++
){


var p=
envState.particles[i];


p.angle+=p.speed;



var px=

cx+
Math.cos(p.angle)
*p.radius;



var py=

cy+
Math.sin(p.angle)
*p.radius;



ctx.fillStyle=color;



ctx.beginPath();

ctx.arc(

px,

py,

2,

0,

Math.PI*2

);



ctx.fill();



}









ctx.save();



ctx.translate(

cx,

cy

);



ctx.scale(

fxState.scale,

fxState.scale

);



ctx.translate(

-cx,

-cy

);



drawHero(
cx,
cy,
color
);



ctx.restore();





drawEffects();



updateAnimation();



requestAnimationFrame(render);



}









/* =========================
   英雄角色
========================= */


function drawHero(x,y,color){



/* 披風 */


ctx.fillStyle=

gameState.jobLevel>=3?

"#700000":

"#111827";



ctx.beginPath();


ctx.moveTo(
x-25,
y+40
);


ctx.lineTo(
x+25,
y+40
);


ctx.lineTo(
x+15,
y-10
);


ctx.lineTo(
x-15,
y-10
);


ctx.closePath();


ctx.fill();






/* 身體 */


ctx.fillStyle="#94a3b8";


ctx.fillRect(

x-15,

y-20,

30,

35

);







/* 頭盔 */


ctx.fillStyle="#475569";


ctx.beginPath();


ctx.arc(

x,

y-35,

15,

0,

Math.PI*2

);


ctx.fill();








/* 眼睛 */


ctx.fillStyle=color;


ctx.fillRect(

x-8,

y-38,

16,

4

);









/* 劍 */


if(
gameState.upgrades.sword.lvl>0
){


ctx.strokeStyle="#ffffff";


ctx.lineWidth=4;



ctx.beginPath();


ctx.moveTo(
x-25,
y
);


ctx.lineTo(
x-25,
y-60
);


ctx.stroke();



}








/* 王冠 */


if(
gameState.upgrades.crown.lvl>0
){


ctx.fillStyle="#f1c40f";


ctx.beginPath();


ctx.moveTo(
x-15,
y-55
);


ctx.lineTo(
x,
y-75
);


ctx.lineTo(
x+15,
y-55
);


ctx.closePath();


ctx.fill();



}




}









/* =========================
   特效
========================= */


function drawEffects(){



for(
var i=0;
i<fxState.waves.length;
i++
){


var w=
fxState.waves[i];



ctx.globalAlpha=w.life;



ctx.strokeStyle=

gameState.jobColors[
gameState.jobLevel
];



ctx.lineWidth=3;



ctx.beginPath();


ctx.arc(

w.x,

w.y,

w.r,

0,

Math.PI*2

);



ctx.stroke();



}



ctx.globalAlpha=1;






for(
var i=0;
i<fxState.texts.length;
i++
){


var t=
fxState.texts[i];



ctx.font=

t.crit?

"bold 28px Arial":

"bold 18px Arial";



ctx.fillStyle=

t.crit?

"#ff3333":

"#ffffff";



ctx.fillText(

t.text,

t.x,

t.y

);



}



}








/* =========================
   遊戲啟動
========================= */


function gameInit(){



loadGame();


initCanvas();


updateUI();


render();



}



</script>


</body>

