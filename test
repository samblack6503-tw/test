<!DOCTYPE html>
<html>
<head>

<meta charset="utf-8">

<title>
豪華轉職：掛機冒險 Ultra Extreme v2.0
</title>


<hta:application
 id="idleGame"
 applicationname="IdleAdventureUltra"
 border="thin"
 borderstyle="normal"
 caption="yes"
 maximizebutton="no"
 minimizebutton="yes"
 showintaskbar="yes"
 singleinstance="yes"
/>


<script>

window.resizeTo(620,720);
window.moveTo(
(window.screen.availWidth-620)/2,
(window.screen.availHeight-720)/2
);



/* ===========================
   遊戲核心資料
=========================== */


var gameState={

    gold:0,

    baseGold:1,

    baseInterval:2000,

    clickPower:1,


    jobLevel:0,


    jobNames:[
        "見習冒險者",
        "皇家聖騎士",
        "元素大魔導",
        "影刃弒神者"
    ],


    jobColors:[
        "#a0a5c1",
        "#f1c40f",
        "#3498db",
        "#e74c3c"
    ],


    rebirthPower:0,


    prestigeRequirement:1200,


    upgrades:{


        sword:{
            name:"光能巨劍",
            lvl:0,
            max:8,
            cost:10,
            baseCost:10,
            mult:1.6
        },


        shield:{
            name:"脈衝重盾",
            lvl:0,
            max:8,
            cost:30,
            baseCost:30,
            mult:1.7
        },


        armor:{
            name:"納米重鎧",
            lvl:0,
            max:8,
            cost:100,
            baseCost:100,
            mult:1.8
        },


        crown:{
            name:"不朽王冠",
            lvl:0,
            max:8,
            cost:500,
            baseCost:500,
            mult:2
        }

    }

};




/* ===========================
   遠征資料
=========================== */


var advState={

    away:false,

    time:0,

    timer:null

};




/* ===========================
   Canvas資料
=========================== */


var canvas=null;

var ctx=null;



var fxState={

    texts:[],

    waves:[],

    scale:1

};



var envState={

    rain:false,

    drops:[],

    stars:[],

    particles:[]

};




/* ===========================
   金幣增加
=========================== */


function addGold(value){

    var maxGold=999999999999;


    gameState.gold=Math.min(

        maxGold,

        gameState.gold+
        Math.floor(value)

    );

}




/* ===========================
   存檔系統
=========================== */


function saveGame(){

    try{


        var data={

            state:gameState,

            time:Date.now()

        };


        window.localStorage.setItem(

            "IdleAdventureSave",

            JSON.stringify(data)

        );


    }
    catch(e){}


}




function loadGame(){


    try{


        var save=

        window.localStorage.getItem(
            "IdleAdventureSave"
        );



        if(!save)
            return;



        var data=
        JSON.parse(save);



        gameState=data.state;



        var offline=

        (Date.now()-data.time)/1000;



        if(offline>5){


            var reward=

            Math.floor(

                getIdleIncome()
                *
                offline
                /
                (getCurrentInterval()/1000)

            );



            reward=Math.min(
                reward,
                999999999
            );



            addGold(reward);



            setTimeout(function(){


                alert(

                "💾 離線收益\n\n"+
                "離線時間："+
                Math.floor(offline)+
                " 秒\n\n"+
                "獲得金幣："+
                reward

                );


            },500);



        }



    }
    catch(e){



    }


}





/* ===========================
   職業倍率
=========================== */


function getJobMultiplier(){


    return [

        1,

        2.5,

        6,

        15

    ][gameState.jobLevel];


}





/* ===========================
   自動收益
=========================== */


function getIdleIncome(){


    var base=

    gameState.baseGold+

    gameState.upgrades.sword.lvl*2;



    var armor=

    1+

    gameState.upgrades.armor.lvl*0.5;



    var total=

    base*armor;



    total*=getJobMultiplier();



    total*=

    (
        1+
        gameState.rebirthPower*0.1
    );



    return Math.floor(total);


}






/* ===========================
   產金速度
=========================== */


function getCurrentInterval(){


    var t=

    gameState.baseInterval-

    gameState.upgrades.shield.lvl*160;



    if(gameState.jobLevel>=2)

        t*=0.7;



    return Math.max(
        250,
        t
    );


}





/* ===========================
   點擊收益
=========================== */


var showCrit=false;



function getClickIncome(){


    var value=

    gameState.clickPower+

    gameState.upgrades.sword.lvl*2;



    value*=

    (
        1+
        gameState.upgrades.crown.lvl*1.5
    );



    value*=getJobMultiplier();



    value*=

    (
        1+
        gameState.rebirthPower*0.1
    );



    if(Math.random()<0.1){


        value*=10;

        showCrit=true;


    }
    else{


        showCrit=false;


    }



    return Math.floor(value);


}



</script>



<style>


html,body{

    width:100%;

    height:100%;

}



*{

    box-sizing:border-box;

    font-family:
    "Microsoft JhengHei";

}



body{

    margin:0;

