<!DOCTYPE html>
<html>
<head>

<meta charset="utf-8">

<title>
豪華轉職：掛機冒險 Ultra Extreme v3.0
</title>

<hta:application
 id="idleGame"
 applicationname="IdleAdventureUltra"
 border="thin"
 caption="yes"
 maximizebutton="no"
 minimizebutton="yes"
 showintaskbar="yes"
 singleinstance="yes"
/>

<style>

*{
box-sizing:border-box;
font-family:"Microsoft JhengHei";
}

body{
margin:0;
padding:12px;
background:#050816;
color:white;
overflow:hidden;
}

.header{
background:#111827;
border:1px solid #45f3ff;
border-radius:12px;
padding:10px;
text-align:center;
}

.gold{
font-size:28px;
font-weight:bold;
color:#f1c40f;
}

.panel{
background:#0f172a;
border:1px solid #334155;
border-radius:12px;
padding:10px;
margin-top:8px;
}

button{
background:#162447;
color:white;
border:1px solid #45f3ff;
padding:8px;
border-radius:8px;
cursor:pointer;
}

button:hover{
background:#1e3a8a;
}

button:disabled{
opacity:.4;
}

.title{
font-size:18px;
color:#45f3ff;
}

.item{
margin:8px 0;
}

</style>


<script>


window.resizeTo(700,760);

window.moveTo(
(screen.width-700)/2,
(screen.height-760)/2
);



/*
================================
  GAME CORE
================================
*/


var SAVE_KEY="IdleAdventureUltra_v3";



var gameState={


gold:0,


totalGold:0,


level:1,


exp:0,


clickPower:1,


baseInterval:2000,



jobLevel:0,


jobs:[

"見習冒險者",

"皇家聖騎士",

"元素大魔導",

"影刃弒神者",

"星界主宰"

],



jobColors:[

"#94a3b8",

"#facc15",

"#38bdf8",

"#ef4444",

"#a855f7"

],



rebirthPower:0,


prestigeCost:1200,



buff:{


goldBonus:0,


damageBonus:0,


speedBonus:0


},



skills:{


rage:{

level:0,

cooldown:60,

time:0

},


fortune:{

level:0,

cooldown:120,

time:0

}


},




equipment:{


sword:{

name:"光能巨劍",

level:0,

max:10,

cost:10,

mult:1.6

},


shield:{

name:"脈衝重盾",

level:0,

max:10,

cost:30,

mult:1.7

},


armor:{

name:"納米重鎧",

level:0,

max:10,

cost:100,

mult:1.8

},


crown:{

name:"不朽王冠",

level:0,

max:10,

cost:500,

mult:2

}


},




missions:{


click:0,


gold:0,


upgrade:0


},



achievements:{


firstJob:false,


million:false,


master:false


}



};





/*
================================
 Canvas
================================
*/


var canvas;

var ctx;



var fx={


texts:[],


waves:[],


scale:1


};



var environment={


stars:[],


particles:[],


rain:[]


};




/*
================================
 初始化資料補全
================================
*/


function mergeObject(target,source){


for(var k in source){


if(
typeof source[k]=="object"
&&
source[k]!=null
&&
!Array.isArray(source[k])
){


if(!target[k])
target[k]={};


mergeObject(
target[k],
source[k]
);


}
else{


if(target[k]===undefined)

target[k]=source[k];


}



}



}






/*
================================
 存檔
================================
*/


function saveGame(){


localStorage[SAVE_KEY]=JSON.stringify({


state:gameState,


time:Date.now()


});


}





function loadGame(){


var data=
localStorage[SAVE_KEY];



if(!data)
return;



try{


var save=
JSON.parse(data);



mergeObject(
gameState,
save.state
);



var offline=
(Date.now()-save.time)/1000;



if(offline>10){



var reward=
Math.floor(
getIdleIncome()
*
offline
/
(getInterval()/1000)
);



reward=Math.min(
reward,
999999999
);



addGold(reward);



setTimeout(function(){


alert(

"💾 離線收益\n\n"+
"時間："+
Math.floor(offline)+
" 秒\n"+
"獲得："+
reward+
" 金幣"

);



},300);



}



}catch(e){


console.log(e);


}



}





/*
================================
 收益計算
================================
*/


function addGold(v){


v=Math.floor(v);



gameState.gold+=v;


gameState.totalGold+=v;



checkAchievement();


}





function getJobMultiplier(){


return [

1,

2.5,

6,

15,

30

][gameState.jobLevel];

}




function getIdleIncome(){


var value=


gameState.level
+
gameState.equipment.sword.level*2;



value*=

(
1+
gameState.equipment.armor.level*0.5
);



value*=getJobMultiplier();



value*=

(
1+
gameState.rebirthPower*0.1
);



value*=

(
1+
gameState.buff.goldBonus
);



return Math.floor(value);


}




function getInterval(){


var t=gameState.baseInterval;



t-=

gameState.equipment.shield.level*150;



t*=

(
1-
gameState.buff.speedBonus
);



if(t<300)

t=300;



return t;


}





/*
================================
 點擊
================================
*/


var critical=false;



function getClickPower(){


var value=


gameState.clickPower
+
gameState.equipment.sword.level*3;



value*=getJobMultiplier();



value*=

(
1+
gameState.buff.damageBonus
);



if(Math.random()<0.1){


value*=10;


critical=true;


}else{


critical=false;


}



return Math.floor(value);


}

 
/*
================================
 Idle Engine
================================
*/


var lastTick=Date.now();



function idleEngine(){


var now=Date.now();


var delta=
now-lastTick;


lastTick=now;



var count=
Math.floor(
delta/getInterval()
);



if(count>0){


addGold(
getIdleIncome()*count
);


updateUI();


}



}




/*
================================
 裝備升級
================================
*/


function buyEquipment(type){


var e=
gameState.equipment[type];



if(
e.level>=e.max
)

return;



if(
gameState.gold>=e.cost
){


gameState.gold-=e.cost;


e.level++;


gameState.missions.upgrade++;



e.cost=
Math.floor(
e.cost*e.mult
);



updateUI();


}



}





/*
================================
 轉職系統
================================
*/


function prestige(){



if(
gameState.jobLevel>=4
)

return;



if(
gameState.gold<
gameState.prestigeCost
)

return;



gameState.gold-=
gameState.prestigeCost;



gameState.jobLevel++;



gameState.rebirthPower++;



gameState.prestigeCost*=6;



gameState.buff.goldBonus+=0.1;



alert(

"✨ 覺醒完成！\n\n"+
"新職業："+
gameState.jobs[
gameState.jobLevel
]+

"\n永久力量 +1"

);



if(
gameState.jobLevel>=1
)

gameState.achievements.firstJob=true;



updateUI();


}




/*
================================
 技能系統
================================
*/


function useSkill(type){



var s=
gameState.skills[type];



if(s.time>0)

return;



if(type=="rage"){


gameState.buff.damageBonus+=0.5;


s.time=s.cooldown;


setTimeout(function(){


gameState.buff.damageBonus-=0.5;


},30000);



}



if(type=="fortune"){


gameState.buff.goldBonus+=1;


s.time=s.cooldown;


setTimeout(function(){


gameState.buff.goldBonus-=1;


},30000);



}



updateUI();


}




function skillTimer(){



for(
var k in gameState.skills
){


var s=
gameState.skills[k];


if(s.time>0)

s.time--;



}



updateUI();


}







/*
================================
 任務與成就
================================
*/


function checkAchievement(){



if(
gameState.totalGold>=1000000
)

gameState.achievements.million=true;



if(
gameState.jobLevel>=4
)

gameState.achievements.master=true;



}







/*
================================
 Canvas 初始化
================================
*/


function initCanvas(){



canvas=
document.getElementById("canvas");



ctx=
canvas.getContext("2d");




for(var i=0;i<40;i++){


environment.stars.push({


x:Math.random()*canvas.width,


y:Math.random()*150,


r:1+Math.random()*2


});


}




for(var i=0;i<40;i++){


environment.particles.push({


angle:Math.random()*6.28,


radius:40+Math.random()*60,


speed:0.01+Math.random()*0.04


});


}




for(var i=0;i<30;i++){


environment.rain.push({


x:Math.random()*canvas.width,


y:Math.random()*canvas.height,


speed:2+Math.random()*5


});


}




}






/*
================================
 Canvas 點擊
================================
*/


function canvasClick(e){



var rect=
canvas.getBoundingClientRect();



var x=
e.clientX-rect.left;


var y=
e.clientY-rect.top;



var value=
getClickPower();



addGold(value);



gameState.missions.click++;



fx.scale=0.8;



fx.texts.push({


x:x,


y:y,


text:
(critical?"CRITICAL ":"+")+
value,


life:100,


crit:critical


});




fx.waves.push({


x:x,


y:y,


r:5,


life:1


});



updateUI();



}





/*
================================
 Canvas 動畫
================================
*/


function animationUpdate(){



if(fx.scale<1)

fx.scale+=0.05;



for(
var i=fx.texts.length-1;
i>=0;i--
){


var t=
fx.texts[i];


t.y-=1;


t.life-=2;



if(t.life<=0)

fx.texts.splice(i,1);


}




for(
var i=fx.waves.length-1;
i>=0;i--
){


var w=
fx.waves[i];


w.r+=4;


w.life-=0.05;



if(w.life<=0)

fx.waves.splice(i,1);



}



}






function render(){



ctx.clearRect(
0,
0,
canvas.width,
canvas.height
);



var bg=
ctx.createLinearGradient(
0,
0,
0,
canvas.height
);



bg.addColorStop(
0,
"#050816"
);



bg.addColorStop(
1,
"#172554"
);



ctx.fillStyle=bg;


ctx.fillRect(
0,
0,
canvas.width,
canvas.height
);





/*
星空
*/


ctx.fillStyle="#fff";



for(
var i=0;
i<environment.stars.length;
i++
){


var s=
environment.stars[i];


ctx.beginPath();


ctx.arc(
s.x,
s.y,
s.r,
0,
Math.PI*2
);


ctx.fill();



}





var cx=
canvas.width/2;


var cy=
canvas.height/2;



var color=
gameState.jobColors[
gameState.jobLevel
];





/*
光環
*/


var aura=
ctx.createRadialGradient(
cx,
cy,
5,
cx,
cy,
90
);



aura.addColorStop(
0,
"#ffffff"
);


aura.addColorStop(
0.4,
color
);


aura.addColorStop(
1,
"transparent"
);



ctx.fillStyle=aura;


ctx.beginPath();


ctx.arc(
cx,
cy,
90,
0,
Math.PI*2
);


ctx.fill();





/*
粒子
*/


for(
var i=0;
i<environment.particles.length;
i++
){


var p=
environment.particles[i];


p.angle+=p.speed;



var px=
cx+
Math.cos(p.angle)
*p.radius;



var py=
cy+
Math.sin(p.angle)
*p.radius;



ctx.fillStyle=color;


ctx.beginPath();


ctx.arc(
px,
py,
2,
0,
Math.PI*2
);


ctx.fill();


}



drawHero(
cx,
cy,
color
);



drawEffects();



animationUpdate();



requestAnimationFrame(render);



}
 
/*
================================
 英雄角色繪製
================================
*/


function drawHero(x,y,color){



/* 披風 */

ctx.fillStyle=
gameState.jobLevel>=3?
"#7f1d1d":
"#111827";

ctx.beginPath();

ctx.moveTo(
x-30,
y+45
);

ctx.lineTo(
x+30,
y+45
);

ctx.lineTo(
x+18,
y-15
);

ctx.lineTo(
x-18,
y-15
);

ctx.closePath();

ctx.fill();





/* 身體 */

ctx.fillStyle="#94a3b8";

ctx.fillRect(
x-18,
y-20,
36,
40
);





/* 頭盔 */

ctx.fillStyle="#475569";

ctx.beginPath();

ctx.arc(
x,
y-40,
18,
0,
Math.PI*2
);

ctx.fill();





/* 眼睛 */

ctx.fillStyle=color;

ctx.fillRect(
x-10,
y-43,
20,
5
);





/* 劍 */

if(
gameState.equipment.sword.level>0
){


ctx.strokeStyle="#ffffff";

ctx.lineWidth=5;


ctx.beginPath();

ctx.moveTo(
x-30,
y
);


ctx.lineTo(
x-30,
y-70
);


ctx.stroke();


}





/* 王冠 */

if(
gameState.equipment.crown.level>0
){


ctx.fillStyle="#facc15";


ctx.beginPath();


ctx.moveTo(
x-20,
y-65
);


ctx.lineTo(
x,
y-90
);


ctx.lineTo(
x+20,
y-65
);


ctx.closePath();


ctx.fill();



}



}






function drawEffects(){



for(
var i=0;
i<fx.waves.length;
i++
){


var w=
fx.waves[i];


ctx.globalAlpha=
w.life;


ctx.strokeStyle=
gameState.jobColors[
gameState.jobLevel
];


ctx.lineWidth=3;


ctx.beginPath();


ctx.arc(
w.x,
w.y,
w.r,
0,
Math.PI*2
);


ctx.stroke();



}



ctx.globalAlpha=1;



for(
var i=0;
i<fx.texts.length;
i++
){


var t=
fx.texts[i];



ctx.font=
t.crit?
"bold 28px Arial":
"bold 18px Arial";



ctx.fillStyle=
t.crit?
"#ef4444":
"#ffffff";



ctx.fillText(
t.text,
t.x,
t.y
);



}



}






/*
================================
 UI 更新
================================
*/


function updateUI(){



if(!document.getElementById("gold"))

return;



document.getElementById("gold").innerHTML=
Math.floor(gameState.gold)+
" 💰";



document.getElementById("job").innerHTML=
gameState.jobs[
gameState.jobLevel
];



document.getElementById("gps").innerHTML=
(
getIdleIncome()
/
(getInterval()/1000)
)
.toFixed(1);



document.getElementById("rebirth").innerHTML=
gameState.rebirthPower;





for(var k in gameState.equipment){



var e=
gameState.equipment[k];



document.getElementById(
"lv-"+k
).innerHTML=
"Lv."+e.level;



document.getElementById(
"cost-"+k
).innerHTML=
e.level>=e.max?
"MAX":
e.cost+" 💰";



}





var p=
document.getElementById("prestige");



if(
gameState.jobLevel>=4
){


p.innerHTML=
"已達最高境界";


p.disabled=true;



}else{


p.disabled=
gameState.gold<
gameState.prestigeCost;



p.innerHTML=
"轉職 → "+
gameState.jobs[
gameState.jobLevel+1
]+
"<br>需求 "+
gameState.prestigeCost+
" 💰";


}





document.getElementById("rage").innerHTML=
gameState.skills.rage.time>0?
"怒氣 "+gameState.skills.rage.time:
"🔥 狂怒";



document.getElementById("fortune").innerHTML=
gameState.skills.fortune.time>0?
"幸運 "+gameState.skills.fortune.time:
"💎 財運";



}





/*
================================
 主循環
================================
*/


setInterval(
idleEngine,
1000
);


setInterval(
skillTimer,
1000
);



setInterval(
saveGame,
10000
);







/*
================================
 初始化
================================
*/


function gameInit(){


loadGame();


initCanvas();


updateUI();


render();



}






</script>

</head>


<body onload="gameInit()">



<div class="header">


<div class="gold">

<span id="gold">
0
</span>

</div>



<div>

職業：

<span id="job">
見習冒險者
</span>

</div>



<div>

每秒收益：

<span id="gps">
0
</span>

</div>



<div>

永久力量：

<span id="rebirth">
0
</span>

</div>


</div>







<div style="
display:flex;
gap:10px;
">





<div class="panel"
style="
width:260px;
height:460px;
">


<canvas
id="canvas"
width="250"
height="450"
onclick="canvasClick(event)"
style="
border-radius:10px;
">
</canvas>


</div>








<div style="width:360px;">





<div class="panel">


<div class="title">
⚔️ 聖殿轉職
</div>


<button
id="prestige"
onclick="prestige()"
style="width:100%">
轉職
</button>


</div>







<div class="panel">


