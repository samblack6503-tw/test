<!DOCTYPE html>
<html>
<head>
    <title>豪華轉職：掛機冒險</title>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta charset="utf-8">
    <style>
        * {
            box-sizing: border-box;
            user-select: none;
            font-family: "Microsoft JhengHei", sans-serif;
        }
        body {
            margin: 0;
            padding: 10px;
            background-color: #1a1a2e;
            color: #ffffff;
            overflow: hidden;
        }
        .container {
            display: flex;
            flex-direction: column;
            height: 100%;
        }
        /* 頂部資訊 */
        .header {
            text-align: center;
            background: #162447;
            padding: 8px;
            border-radius: 8px;
            margin-bottom: 10px;
            border: 1px solid #0f3460;
        }
        .gold-display {
            font-size: 20px;
            font-weight: bold;
            color: #f1c40f;
            text-shadow: 0 0 5px rgba(241, 196, 15, 0.5);
        }
        .stats-display {
            font-size: 11px;
            color: #a2a8d3;
            margin-top: 3px;
        }
        /* 遊戲主體分割 */
        .main-content {
            display: flex;
            flex: 1;
            gap: 10px;
            height: 320px;
        }
        /* 角色區域 */
        .character-area {
            position: relative;
            width: 180px;
            background: #1f4068;
            border-radius: 8px;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            border: 2px solid #e43f5a;
            overflow: hidden;
        }
        .character-area:active {
            transform: scale(0.98);
        }
        #charCanvas {
            background: transparent;
        }
        /* 漂浮文字容器 */
        #float-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }
        .float-text {
            position: absolute;
            color: #f1c40f;
            font-weight: bold;
            font-size: 16px;
            text-shadow: 1px 1px 2px #000;
            animation: floatUp 0.8s ease-out forwards;
        }
        @keyframes floatUp {
            0% { transform: translateY(0px); opacity: 1; }
            100% { transform: translateY(-60px); opacity: 0; }
        }
        /* 商城區域 */
        .shop-area {
            flex: 1;
            background: #162447;
            border-radius: 8px;
            padding: 8px;
            overflow-y: auto;
            border: 1px solid #0f3460;
        }
        .shop-title {
            font-size: 14px;
            font-weight: bold;
            color: #e43f5a;
            margin-bottom: 8px;
            text-align: center;
            border-bottom: 1px solid #0f3460;
            padding-bottom: 3px;
        }
        .shop-item {
            background: #1f4068;
            border-radius: 6px;
            padding: 6px;
            margin-bottom: 6px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid transparent;
        }
        .shop-item:hover {
            border-color: #a2a8d3;
        }
        .item-info {
            display: flex;
            flex-direction: column;
        }
        .item-name {
            font-size: 12px;
            font-weight: bold;
            color: #fff;
        }
        .item-desc {
            font-size: 10px;
            color: #a2a8d3;
        }
        .btn-upgrade {
            background: #e43f5a;
            border: none;
            color: white;
            padding: 5px 8px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 11px;
            font-weight: bold;
        }
        .btn-upgrade:hover {
            background: #ff4a6a;
        }
        .btn-upgrade:disabled {
            background: #4e5166;
            color: #95a5a6;
            cursor: not-allowed;
        }
    </style>
    
    <hta:application 
        id="idleGame"
        applicationname="IdleGame"
        border="thin"
        borderstyle="normal"
        caption="yes"
        icon=""
        maximizebutton="no"
        minimizebutton="yes"
        showintaskbar="yes"
        singleinstance="yes"
        sysmenu="yes"
        windowstate="normal"
    />

    <script>
        // 初始化視窗大小與位置
        window.resizeTo(480, 460);
        window.moveTo(window.screen.availWidth - 500, 100);

        // 遊戲核心數據
        var gameState = {
            gold: 0,
            baseGold: 1,      // 每次獲得的基礎金幣
            goldMultiplier: 1, // 金幣倍率 (由裝備提供)
            baseInterval: 2000, // 基礎間隔 (毫秒)
            intervalReduction: 0, // 減少的時間 (毫秒)
            clickPower: 1,     // 點擊獲得的金幣
            
            // 裝備系統 (與外觀渲染連動)
            upgrades: {
                sword:  { name: "光能巨劍", lvl: 0, max: 5, cost: 10,  costMult: 1.8, desc: "+1 基礎金幣" },
                shield: { name: "脈衝重盾", lvl: 0, max: 5, cost: 30,  costMult: 2.0, desc: "減少 150ms 間隔" },
                armor:  { name: "納米重鎧", lvl: 0, max: 5, cost: 100, costMult: 2.2, desc: "+50% 總金幣收益" },
                crown:  { name: "不朽王冠", lvl: 0, max: 5, cost: 500, costMult: 2.5, desc: "點擊效果大幅增強" }
            }
        };

        var gameTimer = null;
        var canvas, ctx;
        var animAngle = 0; // 用於角色動態懸浮效果

        // 啟動初始化
        function init() {
            canvas = document.getElementById("charCanvas");
            ctx = canvas.getContext("2d");
            
            updateUI();
            startTimer();
            
            // 每一秒渲染 30 次動畫
            setInterval(renderCharacter, 33);
        }

        // 動態計算當前間隔
        function getCurrentInterval() {
            var current = gameState.baseInterval - (gameState.upgrades.shield.lvl * 150);
            return Math.max(400, current); // 最快 0.4 秒一次
        }

        // 動態計算單次掛機收益
        function getIdleIncome() {
            var base = gameState.baseGold + (gameState.upgrades.sword.lvl * 1);
            var mult = 1 + (gameState.upgrades.armor.lvl * 0.5);
            return Math.floor(base * mult);
        }

        // 動態計算點擊收益
        function getClickIncome() {
            var base = gameState.clickPower + (gameState.upgrades.sword.lvl * 0.5);
            var crownBonus = 1 + (gameState.upgrades.crown.lvl * 1.5);
            return Math.floor(base * crownBonus);
        }

        // 控制掛機計時器
        function startTimer() {
            if (gameTimer) clearInterval(gameTimer);
            gameTimer = setInterval(function() {
                var amount = getIdleIncome();
                addGold(amount);
            }, getCurrentInterval());
        }

        // 增加金幣與觸發數字彈窗
        function addGold(amount) {
            gameState.gold += amount;
            createFloatText("+" + amount);
            updateUI();
        }

        // 玩家手動點擊角色
        function onCharacterClick() {
            var amount = getClickIncome();
            addGold(amount);
            // 點擊時讓計時器重置，變相「加快」下一次獲得速度
            startTimer();
        }

        // 浮動文字生成
        function createFloatText(text) {
            var container = document.getElementById("float-container");
            var el = document.createElement("div");
            el.className = "float-text";
            el.innerText = text;
            
            // 隨機在角色頭部上方左右偏離
            var randomX = Math.floor(Math.random() * 60) + 60; 
            el.style.left = randomX + "px";
            el.style.top = "60px";
            
            container.appendChild(el);
            
            // 動態動畫結束後移除節點
            setTimeout(function() {
                if(el && el.parentNode) {
                    container.removeChild(el);
                }
            }, 800);
        }

        // 購買與升級裝備
        function buyUpgrade(type) {
            var upg = gameState.upgrades[type];
            if (gameState.gold >= upg.cost && upg.lvl < upg.max) {
                gameState.gold -= upg.cost;
                upg.lvl++;
                upg.cost = Math.floor(upg.cost * upg.costMult);
                
                updateUI();
                startTimer(); // 更新計時器間隔
            }
        }

        // 更新介面文字與按鈕狀態
        function updateUI() {
            document.getElementById("gold-val").innerText = gameState.gold;
            document.getElementById("gsec-val").innerText = (getIdleIncome() / (getCurrentInterval() / 1000)).toFixed(1);
            document.getElementById("gint-val").innerText = (getCurrentInterval() / 1000).toFixed(2);

            // 更新四個裝備按鈕
            for (var key in gameState.upgrades) {
                var upg = gameState.upgrades[key];
                var btn = document.getElementById("btn-" + key);
                var txtLvl = document.getElementById("lvl-" + key);
                var txtCost = document.getElementById("cost-" + key);
                
                txtLvl.innerText = "Lv." + upg.lvl + (upg.lvl >= upg.max ? " (MAX)" : "");
                
                if (upg.lvl >= upg.max) {
                    txtCost.innerText = "已滿級";
                    btn.disabled = true;
                } else {
                    txtCost.innerText = upg.cost + " 金幣";
                    btn.disabled = (gameState.gold < upg.cost);
                }
            }
        }

        // 純代碼 Canvas 渲染角色外觀
        function renderCharacter() {
            if (!ctx) return;
            
            // 清除畫布
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // 基礎懸浮上下晃動物理效果
            animAngle += 0.05;
            var hoverY = Math.sin(animAngle) * 5;
            
            var centerX = canvas.width / 2;
            var centerY = canvas.height / 2 + 20 + hoverY;
            
            var totalLvl = gameState.upgrades.sword.lvl + 
                           gameState.upgrades.shield.lvl + 
                           gameState.upgrades.armor.lvl + 
                           gameState.upgrades.crown.lvl;

            // 1. 繪製背景魔法陣/光芒 (隨總等級變亮)
            if (totalLvl > 2) {
                ctx.beginPath();
                var gradientRing = ctx.createRadialGradient(centerX, centerY, 10, centerX, centerY, 60 + totalLvl * 3);
                gradientRing.addColorStop(0, 'rgba(230, 126, 34, 0.2)');
                gradientRing.addColorStop(0.5, 'rgba(241, 196, 15, 0.05)');
                gradientRing.addColorStop(1, 'rgba(0,0,0,0)');
                ctx.fillStyle = gradientRing;
                ctx.arc(centerX, centerY, 60 + totalLvl * 3, 0, Math.PI * 2);
                ctx.fill();
            }

            // 2. 繪製背部翅膀外觀 (由鎧甲 Armor 等級解鎖)
            if (gameState.upgrades.armor.lvl >= 2) {
                ctx.fillStyle = gameState.upgrades.armor.lvl >= 4 ? "#f39c12" : "#95a5a6";
                // 左翅膀
                ctx.beginPath();
                ctx.moveTo(centerX - 15, centerY - 10);
                ctx.lineTo(centerX - 55, centerY - 30);
                ctx.lineTo(centerX - 40, centerY + 10);
                ctx.fill();
                // 右翅膀
                ctx.beginPath();
                ctx.moveTo(centerX + 15, centerY - 10);
                ctx.lineTo(centerX + 55, centerY - 30);
                ctx.lineTo(centerX + 40, centerY + 10);
                ctx.fill();
            }

            // 3. 繪製角色法陣底座 (隨盾牌 Shield 等級升級)
            ctx.lineWidth = 3;
            ctx.strokeStyle = gameState.upgrades.shield.lvl > 0 ? "#3498db" : "#7f8c8d";
            ctx.save();
            ctx.translate(centerX, centerY + 40);
            ctx.scale(1, 0.3);
            ctx.beginPath();
            ctx.arc(0, 0, 30 + gameState.upgrades.shield.lvl * 4, 0, Math.PI * 2);
            ctx.stroke();
            if (gameState.upgrades.shield.lvl >= 3) {
                ctx.fillStyle = "rgba(52, 152, 219, 0.3)";
                ctx.fill();
            }
            ctx.restore();

            // 4. 繪製角色本體核心 (隨鎧甲 Armor 等級變得精緻)
            ctx.beginPath();
            var bodyColor = "#34495e";
            if (gameState.upgrades.armor.lvl > 0) bodyColor = "#5271ff";
            if (gameState.upgrades.armor.lvl >= 3) bodyColor = "#9b59b6";
            if (gameState.upgrades.armor.lvl == 5) bodyColor = "#1abc9c";
            ctx.fillStyle = bodyColor;
            ctx.arc(centerX, centerY, 20, 0, Math.PI * 2);
            ctx.fill();
            
            // 核心面具/眼睛
            ctx.fillStyle = "#ffffff";
            ctx.fillRect(centerX - 8, centerY - 4, 4, 4);
            ctx.fillRect(centerX + 4, centerY - 4, 4, 4);

            // 5. 繪製武器-光能巨劍 (由劍 Sword 等級解鎖與變長)
            if (gameState.upgrades.sword.lvl > 0) {
                ctx.lineWidth = 4 + gameState.upgrades.sword.lvl;
                ctx.strokeStyle = gameState.upgrades.sword.lvl >= 4 ? "#e74c3c" : "#e67e22";
                ctx.beginPath();
                // 武器隨時間輕微揮動
                var swordSwing = Math.sin(animAngle * 2) * 3;
                ctx.moveTo(centerX - 22, centerY + 15);
                ctx.lineTo(centerX - 35 - gameState.upgrades.sword.lvl * 3, centerY - 15 + swordSwing);
                ctx.stroke();
            }

            // 6. 繪製防具-脈衝重盾 (由盾 Shield 等級解鎖)
            if (gameState.upgrades.shield.lvl > 0) {
                ctx.fillStyle = "#2980b9";
                ctx.strokeStyle = "#ffffff";
                ctx.lineWidth = 1;
                ctx.beginPath();
                ctx.rect(centerX + 15, centerY - 5, 12, 20 + gameState.upgrades.shield.lvl * 2);
                ctx.fill();
                ctx.stroke();
            }

            // 7. 繪製頭頂裝飾-不朽王冠 (由王冠 Crown 等級解鎖與進化)
            if (gameState.upgrades.crown.lvl > 0) {
                ctx.fillStyle = "#f1c40f";
                var crownY = centerY - 22;
                ctx.beginPath();
                ctx.moveTo(centerX - 12, crownY);
                ctx.lineTo(centerX - 15, crownY - 8 - gameState.upgrades.crown.lvl);
                ctx.lineTo(centerX - 5, crownY - 4);
                ctx.lineTo(centerX, crownY - 14 - gameState.upgrades.crown.lvl * 2); // 主冠尖
                ctx.lineTo(centerX + 5, crownY - 4);
                ctx.lineTo(centerX + 15, crownY - 8 - gameState.upgrades.crown.lvl);
                ctx.lineTo(centerX + 12, crownY);
                ctx.closePath();
                ctx.fill();
                
                // 頂級王冠寶石特效
                if (gameState.upgrades.crown.lvl >= 3) {
                    ctx.fillStyle = "#e74c3c";
                    ctx.beginPath();
                    ctx.arc(centerX, crownY - 16 - gameState.upgrades.crown.lvl * 2, 3, 0, Math.PI * 2);
                    ctx.fill();
                }
            }
        }
    </script>
</head>
<body onload="init()">

    <div class="container">
        
        <div class="header">
            <div class="gold-display">儲備金幣: <span id="gold-val">0</span> 💰</div>
            <div class="stats-display">
                預估時薪: <span id="gsec-val">0.5</span>/秒 | 
                結算週期: <span id="gint-val">2.00</span>秒
            </div>
        </div>

        <div class="main-content">
            
            <div class="character-area" onclick="onCharacterClick()">
                <canvas id="charCanvas" width="180" height="310"></canvas>
                <div id="float-container"></div>
            </div>

            <div class="shop-area">
                <div class="shop-title">皇家軍備整備處</div>
                
                <div class="shop-item">
                    <div class="item-info">
                        <span class="item-name">⚔️ 光能巨劍 <span id="lvl-sword" style="color:#e67e22">Lv.0</span></span>
                        <span class="item-desc">加強攻擊力。+1 基礎金幣</span>
                    </div>
                    <button class="btn-upgrade" id="btn-sword" onclick="buyUpgrade('sword')">
                        <span id="cost-sword">10 金幣</span>
                    </button>
                </div>

                <div class="shop-item">
                    <div class="item-info">
                        <span class="item-name">🛡️ 脈衝重盾 <span id="lvl-shield" style="color:#3498db">Lv.0</span></span>
                        <span class="item-desc">提高效率。縮短 150ms 掛機間隔</span>
                    </div>
                    <button class="btn-upgrade" id="btn-shield" onclick="buyUpgrade('shield')">
                        <span id="cost-shield">30 金幣</span>
                    </button>
                </div>

                <div class="shop-item">
                    <div class="item-info">
                        <span class="item-name">🛡️ 納米重鎧 <span id="lvl-armor" style="color:#9b59b6">Lv.0</span></span>
                        <span class="item-desc">領主威嚴。所有收益提升 50%</span>
                    </div>
                    <button class="btn-upgrade" id="btn-armor" onclick="buyUpgrade('armor')">
                        <span id="cost-armor">100 金幣</span>
                    </button>
                </div>

                <div class="shop-item">
                    <div class="item-info">
                        <span class="item-name">👑 不朽王冠 <span id="lvl-crown" style="color:#f1c40f">Lv.0</span></span>
                        <span class="item-desc">神聖加持。大幅增幅點擊產出</span>
                    </div>
                    <button class="btn-upgrade" id="btn-crown" onclick="buyUpgrade('crown')">
                        <span id="cost-crown">500 金幣</span>
                    </button>
                </div>

            </div>
            
        </div>
    </div>

</body>
</html>
