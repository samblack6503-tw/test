</head>
<body onload="gameInit()">


<div class="header">

<div class="gold">
💰 <span id="gold">0</span>
</div>


<div>
職業：
<span id="job">
見習冒險者
</span>
</div>


<div>
每秒收益：
<span id="gps">
0
</span>
</div>


<div>
永久力量：
<span id="rebirth">
0
</span>
</div>


</div>





<div style="
display:flex;
gap:10px;
margin-top:10px;
">


<!-- Canvas區 -->

<div class="panel"
style="
width:230px;
height:430px;
padding:5px;
">


<canvas
id="canvas"
width="220"
height="420"
onclick="canvasClick(event)"
style="
border-radius:10px;
">
</canvas>


</div>






<!-- 功能區 -->


<div style="
width:330px;
">



<div class="panel">


<h3>
⚔️ 聖殿轉職
</h3>


<button
id="prestige"
onclick="triggerPrestige()"
style="width:100%"
>

轉職

</button>


</div>






<div class="panel">


<h3>
🛠 軍備升級
</h3>




<div>

⚔️ 光能巨劍

<span id="lv-sword">
Lv.0
</span>


<button onclick="
buyUpgrade('sword')
">

<span id="cost-sword">
10
</span>

</button>

</div>



<br>




<div>

🛡️ 脈衝重盾

<span id="lv-shield">
Lv.0
</span>


<button onclick="
buyUpgrade('shield')
">

<span id="cost-shield">
30
</span>

</button>

</div>



<br>




<div>

👕 納米重鎧

<span id="lv-armor">
Lv.0
</span>


<button onclick="
buyUpgrade('armor')
">

<span id="cost-armor">
100
</span>

</button>


</div>




<br>





<div>

👑 不朽王冠

<span id="lv-crown">
Lv.0
</span>


<button onclick="
buyUpgrade('crown')
">


<span id="cost-crown">
500
</span>


</button>


</div>



</div>







<div
class="panel"
id="adv"
style="display:none"
>


<h3>
🌎 邊境遠征
</h3>



<button
id="advBtn"
onclick="startAdventure()"
style="width:100%"
>

開始遠征

</button>


</div>





